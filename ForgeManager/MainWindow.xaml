<Window x:Class="ForgeManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForgeManager"
        Width="1380" Height="880" MinWidth="980" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        Foreground="{StaticResource TextPrimary}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Background="{StaticResource WindowBackground}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel MaxWidth="1040">
                <TextBlock Text="ForgeManager" FontSize="28" FontWeight="Bold"/>
                <TextBlock Text="An Arma Reforger server GUI interface for Windows 10/11" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Accent}" Margin="0,3,0,0"/>
                <TextBlock Text="Process control • external-instance attach • live terminal • filtered logs • configuration editor • Workshop mod browser • kill feed • player and admin events • network tools" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="AppModeText" Text="Detecting server layout..." Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Border Grid.Column="1" Background="{StaticResource PanelBackgroundAlt}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="16,9">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="HeaderStatusDot" Width="10" Height="10" Fill="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="HeaderStatusText" Text="OFFLINE" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="8" Margin="0,0,0,12">
            <WrapPanel>
                <Button x:Name="StartButton" Content="Start Server" Click="StartServer_Click"/>
                <Button x:Name="StopButton" Content="Stop" Style="{StaticResource DangerButton}" Click="StopServer_Click" IsEnabled="False"/>
                <Button x:Name="RestartButton" Content="Restart" Style="{StaticResource SecondaryButton}" Click="RestartServer_Click" IsEnabled="False"/>
                <Button Content="Repair + Start" Style="{StaticResource SecondaryButton}" Click="RepairStart_Click"/>
                <Button x:Name="LaunchLocalClientButton" Content="Launch Local Client" Style="{StaticResource SecondaryButton}" Click="LaunchLocalClient_Click" IsEnabled="False"/>
                <Button Content="Add UDP Firewall Rule" Style="{StaticResource SecondaryButton}" Click="AddFirewallRule_Click"/>
                <CheckBox x:Name="AutoRestartCheckBox" Content="Auto restart" VerticalAlignment="Center" Checked="AutoRestart_Changed" Unchecked="AutoRestart_Changed"/>
            </WrapPanel>
        </Border>

        <TabControl Grid.Row="2" x:Name="MainTabs" Background="{StaticResource WindowBackground}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,12,0,0">
                    <StackPanel>
                        <WrapPanel>
                            <Border Width="250" MinHeight="116" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="SERVER STATUS" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DashboardStatusText" Text="Offline" FontSize="24" FontWeight="Bold" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Width="250" MinHeight="116" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="UPTIME" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="UptimeText" Text="00:00:00" FontSize="24" FontWeight="Bold" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Width="250" MinHeight="116" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="PROCESS" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ProcessText" Text="No process" FontSize="20" FontWeight="Bold" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Width="360" MinHeight="116" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="6">
                                <StackPanel>
                                    <TextBlock Text="UDP LISTENER" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ListenerText" Text="Not listening" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <Grid Margin="6,12,6,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="420"/>
                                <ColumnDefinition Width="*" MinWidth="320"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Text="Active configuration" FontSize="18" FontWeight="Bold"/>
                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Server" Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                                        <TextBlock Grid.Column="1" x:Name="SummaryServerName" Text="—" TextWrapping="Wrap" Margin="0,4"/>
                                        <TextBlock Grid.Row="1" Text="Scenario" Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="SummaryScenario" Text="—" TextWrapping="Wrap" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Text="Players" Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="SummaryPlayers" Text="—" Margin="0,4"/>
                                        <TextBlock Grid.Row="3" Text="Explicit mods" Foreground="{StaticResource TextMuted}" Margin="0,4"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="SummaryMods" Text="—" Margin="0,4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="6,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Connection diagnostics" FontSize="18" FontWeight="Bold"/>
                                    <TextBlock Text="LAN IPv4" Foreground="{StaticResource TextMuted}" Margin="0,14,0,2"/>
                                    <TextBlock x:Name="LanAddressText" Text="—" FontSize="17"/>
                                    <TextBlock Text="Local test" Foreground="{StaticResource TextMuted}" Margin="0,12,0,2"/>
                                    <TextBlock x:Name="LocalTargetText" Text="127.0.0.1:2001" FontSize="17"/>
                                    <TextBlock x:Name="LocalConnectionStatusText" Text="Waiting for listener status." Foreground="{StaticResource Accent}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                    <TextBlock Text="Public-list visibility confirms backend registration, not inbound UDP reachability." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,14,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="18" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Latest event" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="LatestEventText" Text="No server output yet." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Terminal">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8">
                        <WrapPanel>
                            <Button Content="Clear view" Style="{StaticResource SecondaryButton}" Click="ClearTerminal_Click"/>
                            <CheckBox x:Name="AutoScrollCheckBox" Content="Auto-scroll" IsChecked="True" VerticalAlignment="Center"/>
                            <TextBlock Text="Managed output is captured directly; attached instances are tailed from profile logs." Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </WrapPanel>
                    </Border>
                    <RichTextBox Grid.Row="1" x:Name="TerminalBox" IsReadOnly="True" FontFamily="Cascadia Mono, Consolas" FontSize="13" Background="#070D16" Foreground="#D8E5F6" BorderBrush="{StaticResource PanelBorder}" Padding="12" VerticalScrollBarVisibility="Auto"/>
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TerminalInput" KeyDown="TerminalInput_KeyDown" ToolTip="Send a line to server stdin. Some server builds ignore console input."/>
                        <Button x:Name="SendTerminalButton" Grid.Column="1" Content="Send" Click="SendTerminalInput_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Log Table">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8">
                        <WrapPanel>
                            <TextBox x:Name="LogSearchBox" Width="240" TextChanged="LogFilter_Changed" ToolTip="Filter message text"/>
                            <CheckBox x:Name="BackendFilter" Content="BACKEND" IsChecked="True" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <CheckBox x:Name="NetworkFilter" Content="NETWORK" IsChecked="True" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <CheckBox x:Name="EngineFilter" Content="ENGINE" IsChecked="True" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <CheckBox x:Name="PlatformFilter" Content="PLATFORM" IsChecked="True" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <CheckBox x:Name="OtherFilter" Content="OTHER TYPES" IsChecked="True" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <CheckBox x:Name="ErrorsOnlyFilter" Content="ERRORS ONLY" Checked="LogFilter_Changed" Unchecked="LogFilter_Changed"/>
                            <Button Content="Clear table" Style="{StaticResource SecondaryButton}" Click="ClearLogs_Click"/>
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="LogDataGrid" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Category}" Width="125"/>
                            <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="95"/>
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Kill Feed">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Console-driven kill feed" FontWeight="Bold"/>
                                <TextBlock x:Name="KillFeedStatusText" Text="Waiting for kill events in server output." Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="The feed displays events emitted by the active scenario or logging mod; Reforger does not guarantee a vanilla dedicated-server kill line for every game mode." Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Clear feed" Style="{StaticResource SecondaryButton}" Click="ClearKillFeed_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1" x:Name="KillFeedDataGrid" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="105"/>
                            <DataGridTextColumn Header="Killer" Binding="{Binding Killer}" Width="*" MinWidth="170"/>
                            <DataGridTextColumn Header="Victim" Binding="{Binding Victim}" Width="*" MinWidth="170"/>
                            <DataGridTextColumn Header="Weapon" Binding="{Binding Weapon}" Width="220"/>
                            <DataGridTextColumn Header="Distance" Binding="{Binding Distance}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Admin Events">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="2*" MinHeight="210"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="3*" MinHeight="260"/>
                    </Grid.RowDefinitions>
                    <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Player and Game Master activity" FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Background="{StaticResource PanelBackgroundAlt}" CornerRadius="8" Padding="9,4" Margin="12,0,0,0">
                                    <TextBlock x:Name="ActivePlayerCountText" Text="0 active players" Foreground="{StaticResource Accent}" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Clear event history" Style="{StaticResource SecondaryButton}" Click="ClearAdminEvents_Click"/>
                        </Grid>
                    </Border>
                    <GroupBox Grid.Row="1" Header="Active players">
                        <DataGrid x:Name="ActivePlayersDataGrid" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Player" Binding="{Binding DisplayName}" Width="*" MinWidth="220"/>
                                <DataGridTextColumn Header="Player ID" Binding="{Binding PlayerId}" Width="190"/>
                                <DataGridTextColumn Header="IP / endpoint" Binding="{Binding Address}" Width="190"/>
                                <DataGridTextColumn Header="Connected" Binding="{Binding ConnectedAt, StringFormat={}{0:HH:mm:ss}}" Width="110"/>
                                <DataGridTextColumn Header="Online for" Binding="{Binding ConnectedFor}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                    <GridSplitter Grid.Row="2" Height="6" HorizontalAlignment="Stretch" Background="{StaticResource PanelBorder}"/>
                    <GroupBox Grid.Row="3" Header="Join, leave and Game Master events">
                        <DataGrid x:Name="AdminEventsDataGrid" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False" AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" Width="90"/>
                                <DataGridTextColumn Header="Event" Binding="{Binding EventType}" Width="130"/>
                                <DataGridTextColumn Header="Player / actor" Binding="{Binding Player}" Width="220"/>
                                <DataGridTextColumn Header="IP / endpoint" Binding="{Binding Address}" Width="180"/>
                                <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <TabItem Header="Configuration">
                <TabControl Margin="0,12,0,0">
                    <TabItem Header="Guided editor">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="0,8,10,8">
                                <GroupBox Header="Identity and session">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="240"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Server name" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="ServerNameBox"/>
                                        <TextBlock Grid.Column="2" Text="Max players" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="3" x:Name="MaxPlayersBox"/>

                                        <TextBlock Grid.Row="1" Text="Scenario ID" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="ScenarioIdBox"/>

                                        <TextBlock Grid.Row="2" Text="Server password" VerticalAlignment="Center"/>
                                        <PasswordBox Grid.Row="2" Grid.Column="1" x:Name="ServerPasswordBox"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Admin password" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <PasswordBox Grid.Row="2" Grid.Column="3" x:Name="AdminPasswordBox" ToolTip="Set a unique admin password. Leave blank when password-based admin login is not needed."/>

                                        <CheckBox Grid.Row="3" Grid.Column="1" x:Name="VisibleCheckBox" Content="Visible in server browser"/>
                                        <CheckBox Grid.Row="3" Grid.Column="2" x:Name="CrossplayCheckBox" Content="Crossplay"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Network and gameplay">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="220"/>
                                            <ColumnDefinition Width="190"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="Bind address" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="BindAddressBox" ToolTip="Blank is recommended and lets Reforger select its interface."/>
                                        <TextBlock Grid.Column="2" Text="Public address" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Column="3" x:Name="PublicAddressBox" ToolTip="Normally blank for automatic public-IP detection."/>

                                        <TextBlock Grid.Row="1" Text="Bind port" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="BindPortBox"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="Public port" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" x:Name="PublicPortBox"/>

                                        <TextBlock Grid.Row="2" Text="Max view distance" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="MaxViewDistanceBox"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Network view distance" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <TextBox Grid.Row="2" Grid.Column="3" x:Name="NetworkViewDistanceBox"/>

                                        <TextBlock Grid.Row="3" Text="Minimum grass distance" VerticalAlignment="Center"/>
                                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="GrassDistanceBox" ToolTip="Arma Reforger schema maximum: 150"/>
                                        <CheckBox Grid.Row="3" Grid.Column="2" x:Name="DisableThirdPersonCheckBox" Content="Disable third person"/>
                                        <CheckBox Grid.Row="3" Grid.Column="3" x:Name="BattleEyeCheckBox" Content="BattlEye"/>

                                        <CheckBox Grid.Row="4" Grid.Column="1" x:Name="FastValidationCheckBox" Content="Fast validation"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Text="Blank bindAddress is recommended. The manager automatically follows the actual UDP listener for same-PC joining." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="16,6,0,0"/>
                                    </Grid>
                                </GroupBox>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="6,8">
                                    <TextBlock x:Name="ConfigStatusText" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                    <Button Content="Reload" Style="{StaticResource SecondaryButton}" Click="ReloadConfig_Click"/>
                                    <Button Content="Validate" Style="{StaticResource SecondaryButton}" Click="ValidateConfig_Click"/>
                                    <Button Content="Save configuration" Click="SaveGuidedConfig_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Raw JSON">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox x:Name="RawJsonBox" AcceptsReturn="True" AcceptsTab="True" FontFamily="Cascadia Mono, Consolas" FontSize="13" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Reload raw" Style="{StaticResource SecondaryButton}" Click="ReloadRawConfig_Click"/>
                                <Button Content="Validate + save raw" Click="SaveRawConfig_Click"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Mods">
                <TabControl Margin="0,12,0,0">
                    <TabItem Header="Configured Mods">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button Content="Refresh metadata" Click="RefreshWorkshop_Click"/>
                                        <Button Content="Use minimal CIE Udachne list" Style="{StaticResource SecondaryButton}" Click="UseMinimalMods_Click"/>
                                        <Button Content="Open config folder" Style="{StaticResource SecondaryButton}" Click="OpenConfigFolder_Click"/>
                                        <TextBox x:Name="ModSearchBox" Width="220" TextChanged="ModSearch_Changed" ToolTip="Filter configured addons and dependencies"/>
                                        <TextBlock x:Name="WorkshopStatusText" Text="Workshop data not loaded." Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </WrapPanel>
                                    <WrapPanel Margin="0,6,0,0">
                                        <TextBox x:Name="AddModIdBox" Width="390" ToolTip="Paste a 16-character Workshop ID or official Workshop URL"/>
                                        <Button Content="Add Workshop mod" Click="AddModById_Click"/>
                                        <TextBlock x:Name="ModActionStatusText" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="12,0,0,0" TextWrapping="Wrap"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="ModsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="132"/>
                                                        <ColumnDefinition Width="2*" MinWidth="260"/>
                                                        <ColumnDefinition Width="*" MinWidth="230"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="116" Height="76" Background="#09111D" CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Left">
                                                        <Image Source="{Binding ThumbnailUri}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="4,0,18,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
                                                            <Border Background="{StaticResource PanelBackgroundAlt}" CornerRadius="8" Padding="7,3" Margin="10,0,0,0">
                                                                <TextBlock Text="{Binding Role}" Foreground="{StaticResource Accent}" FontSize="11" FontWeight="Bold"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding ModId}" Foreground="{StaticResource TextMuted}" FontFamily="Consolas" Margin="0,5,0,0"/>
                                                        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" MaxHeight="42" Margin="0,7,0,0"/>
                                                    </StackPanel>
                                                    <Grid Grid.Column="2">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                        <TextBlock Text="Version" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Version}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Text="Game version" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GameVersion}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Text="Popularity" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PopularitySummary}" Margin="0,2" TextWrapping="Wrap"/>
                                                        <TextBlock Grid.Row="3" Text="Dependencies" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DependencySummary}" Margin="0,2"/>
                                                    </Grid>
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="14,0,0,0">
                                                        <TextBlock Text="{Binding AvailabilityText}" Foreground="{StaticResource Accent}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                        <Button Content="Workshop" Tag="{Binding WorkshopUrl}" Style="{StaticResource SecondaryButton}" Click="OpenWorkshop_Click"/>
                                                        <Button Content="Remove" Tag="{Binding ModId}" Style="{StaticResource DangerButton}" IsEnabled="{Binding CanRemove}" Click="RemoveConfiguredMod_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Available Workshop">
                        <Grid Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="8" Margin="0,0,0,8">
                                <StackPanel>
                                    <WrapPanel>
                                        <TextBox x:Name="AvailableWorkshopSearchBox" Width="360" KeyDown="AvailableWorkshopSearch_KeyDown" ToolTip="Search the official Arma Reforger Workshop"/>
                                        <Button Content="Search Workshop" Click="BrowseWorkshopSearch_Click"/>
                                        <Button Content="Open official Workshop" Style="{StaticResource SecondaryButton}" Click="OpenWorkshopHome_Click"/>
                                        <Button x:Name="PreviousWorkshopPageButton" Content="Previous" Style="{StaticResource SecondaryButton}" Click="BrowseWorkshopPrevious_Click" IsEnabled="False"/>
                                        <Button x:Name="NextWorkshopPageButton" Content="Next" Style="{StaticResource SecondaryButton}" Click="BrowseWorkshopNext_Click" IsEnabled="False"/>
                                        <TextBlock x:Name="WorkshopPageText" Text="Page 1" Foreground="{StaticResource Accent}" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </WrapPanel>
                                    <TextBlock x:Name="AvailableWorkshopStatusText" Text="Search or load the official Workshop to browse available addons." Foreground="{StaticResource TextMuted}" Margin="5,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl x:Name="AvailableWorkshopItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="132"/>
                                                        <ColumnDefinition Width="2*" MinWidth="280"/>
                                                        <ColumnDefinition Width="*" MinWidth="240"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="116" Height="76" Background="#09111D" CornerRadius="8" ClipToBounds="True" HorizontalAlignment="Left">
                                                        <Image Source="{Binding ThumbnailUri}" Stretch="UniformToFill"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="1" Margin="4,0,18,0">
                                                        <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="Bold"/>
                                                        <TextBlock Margin="0,4,0,0" Foreground="{StaticResource TextMuted}"><Run Text="by "/><Run Text="{Binding Author}"/><Run Text="  ·  "/><Run Text="{Binding ModId}"/></TextBlock>
                                                        <TextBlock Text="{Binding Summary}" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" MaxHeight="48" Margin="0,7,0,0"/>
                                                    </StackPanel>
                                                    <Grid Grid.Column="2">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="105"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                                        <TextBlock Text="Version" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Version}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Text="Game version" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GameVersion}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Text="Size" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Size}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="3" Text="Popularity" Foreground="{StaticResource TextMuted}" Margin="0,2"/>
                                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PopularitySummary}" Margin="0,2" TextWrapping="Wrap"/>
                                                    </Grid>
                                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="14,0,0,0">
                                                        <TextBlock Text="{Binding AvailabilityText}" Foreground="{StaticResource Accent}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                        <Button Content="Add to config" Tag="{Binding ModId}" IsEnabled="{Binding CanAdd}" Click="AddAvailableMod_Click"/>
                                                        <Button Content="Workshop" Tag="{Binding WorkshopUrl}" Style="{StaticResource SecondaryButton}" Click="OpenWorkshop_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>


            <TabItem Header="SteamCMD Setup">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <GroupBox Header="Automatic Arma Reforger Server Install">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <TextBlock Text="SteamCMD folder" VerticalAlignment="Center"/><TextBox Grid.Column="1" x:Name="SteamCmdPathBox"/><Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseSteamCmdFolder_Click"/>
                            <TextBlock Grid.Row="1" Text="Server install folder" VerticalAlignment="Center"/><TextBox Grid.Row="1" Grid.Column="1" x:Name="ServerInstallPathBox"/><Button Grid.Row="1" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseServerInstallFolder_Click"/>
                            <TextBlock Grid.Row="2" Text="Release channel" VerticalAlignment="Center"/><ComboBox Grid.Row="2" Grid.Column="1" x:Name="ServerBranchBox" SelectedIndex="0"><ComboBoxItem Content="Stable (App 1874900)"/><ComboBoxItem Content="Experimental (App 1890870)"/></ComboBox>
                            <CheckBox Grid.Row="3" Grid.Column="1" x:Name="ValidateServerFilesCheckBox" Content="Validate all files (recommended for repair)" IsChecked="True"/>
                        </Grid>
                    </GroupBox>
                    <Border Grid.Row="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="10" Margin="6">
                        <StackPanel><WrapPanel><Button x:Name="InstallSteamCmdButton" Content="Install SteamCMD + Server" Click="InstallSteamCmdAndServer_Click"/><Button x:Name="UpdateServerButton" Content="Update / Verify Server" Style="{StaticResource SecondaryButton}" Click="UpdateServer_Click"/><Button x:Name="CancelSteamCmdButton" Content="Cancel" Style="{StaticResource SecondaryButton}" Click="CancelSteamCmd_Click" IsEnabled="False"/><Button Content="Open server folder" Style="{StaticResource SecondaryButton}" Click="OpenServerInstallFolder_Click"/></WrapPanel><ProgressBar x:Name="SteamCmdProgressBar" Height="8" Minimum="0" Maximum="100" Margin="4,10,4,0"/><TextBlock x:Name="SteamCmdStatusText" Text="Ready" Foreground="{StaticResource TextMuted}" Margin="4,8,4,0"/></StackPanel>
                    </Border>
                    <TextBox Grid.Row="2" x:Name="SteamCmdOutputBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" FontFamily="Cascadia Mono, Consolas" Background="#070D16" Foreground="#D8E5F6" BorderBrush="{StaticResource PanelBorder}" Padding="12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,12,0,0">
                    <StackPanel>
                        <Border Background="{StaticResource PanelBackgroundAlt}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="6">
                            <StackPanel>
                                <TextBlock Text="Drop-in server layout" FontWeight="Bold"/>
                                <TextBlock x:Name="PortableLayoutText" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                                <TextBlock Text="Place the published ForgeManager.exe in the same directory as ArmaReforgerServer.exe. ForgeManager will automatically load .\configs\config.json and .\profile on every launch." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        <GroupBox Header="Paths">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Server executable" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="ServerExePathBox"/>
                                <Button Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseServerExe_Click"/>
                                <TextBlock Grid.Row="1" Text="Config JSON" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ConfigPathBox"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseConfig_Click"/>
                                <TextBlock Grid.Row="2" Text="Profile folder" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ProfilePathBox"/>
                                <Button Grid.Row="2" Grid.Column="2" Content="Use server profile" Style="{StaticResource SecondaryButton}" Click="UseDefaultProfile_Click"/>
                                <TextBlock Grid.Row="3" Text="Game client executable" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" x:Name="ClientExePathBox"/>
                                <Button Grid.Row="3" Grid.Column="2" Content="Browse" Style="{StaticResource SecondaryButton}" Click="BrowseClientExe_Click"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Runtime">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="190"/>
                                    <ColumnDefinition Width="220"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Maximum server FPS" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1" x:Name="MaxFpsBox"/>
                                <TextBlock Grid.Column="2" Text="Restart delay (seconds)" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                <TextBox Grid.Column="3" x:Name="RestartDelayBox"/>
                                <TextBlock Grid.Row="1" Text="Local join address" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="LocalJoinAddressBox"/>
                                <CheckBox Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" x:Name="AutoDetectJoinAddressCheckBox" Content="Auto-detect from bindAddress and the active UDP listener" IsChecked="True" Checked="AutoDetectJoinAddress_Changed" Unchecked="AutoDetectJoinAddress_Changed" Margin="16,4,0,4"/>
                            </Grid>
                        </GroupBox>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="6,8">
                            <TextBlock x:Name="SettingsStatusText" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,14,0"/>
                            <Button Content="Save settings" Click="SaveSettings_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
